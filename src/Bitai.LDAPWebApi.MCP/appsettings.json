{
  "LdapMcp": {
    "TransportMode": "StreamableHttp",
    "StreamableHttpCors": {
      "AllowAnyOrigin": true,
      "AllowedOrigins": [
        "http://localhost",
        "http://localhost:8080"
      ]
    },
    "LDAPWebApiServer": {
      "ApiBaseUrl": "http://localhost:5100",
      "DefaultLdapServerProfile": "DOMAIN_PROFILEID",
      "UseGlobalCatalog": false,
      "UseBearerToken": false,
      "OAuth": {
        "AuthorityUrl": "https://localhost/IsSts9",
        "ApiScope": "Bitai.LdapWebApi.Local.ApiScope.Reader",
        "ClientId": "Bitai.LdapWebApi.Local.Machine.Client",
        "ClientSecret": "<change-me>"
      }
    },
    "DefaultRequestLabel": "LWAMCP",
    "RequestTimeoutSeconds": 5,
    "MaxRetries": 3,
    "RetryDelayMilliseconds": 500
  }
}
